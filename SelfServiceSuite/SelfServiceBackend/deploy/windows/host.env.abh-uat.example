PORT=4000
HOST=0.0.0.0
PORTAL_STATIC_DIR=public

# Portal URL — this Windows host IP (see show-host-address.ps1).
CORS_ORIGIN=http://146.161.102.7:4000

# ABH UAT Business Central (NOT Hijra Bank).
# OData = port 7048, SOAP / ODataV4 pages = port 7047.
BC_ODATA_BASE_URL=http://abh-erp-ml:7048/BC240/ODataV4/Company('ABH%20UAT%20LIVE')/
BC_SOAP_CODEUNIT_URL=http://abh-erp-ml:7047/BC240/WS/ABH%20UAT%20LIVE/Codeunit/CuStaffPortal
BC_SOAP_PAGE_BASE_URL=http://abh-erp-ml:7047/BC240/ODataV4/Company('ABH%20UAT%20LIVE')/
BC_SOAP_NAMESPACE=urn:microsoft-dynamics-schemas/codeunit/CuStaffPortal

# ABH UAT typically uses Basic auth (confirm with your BC admin).
BC_AUTH_MODE=Basic
BC_DOMAIN=
BC_NAV_USER=Admin
BC_NAV_PASSWORD=REPLACE-WITH-REAL-PASSWORD

SESSION_SECRET=REPLACE-WITH-A-LONG-RANDOM-SECRET
JWT_SECRET=REPLACE-WITH-A-DIFFERENT-RANDOM-SECRET-AT-LEAST-32-CHARACTERS
JWT_TTL_SECONDS=28800

LOG_API_REQUESTS=true
LOG_BC_REQUESTS=true
BC_LOG_FILE=bc-integration.log

SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_SECURE=false
HOD_OVERRIDE_EMPNOS=
CEO_OVERRIDE_EMPNOS=
