PORT=4000
HOST=0.0.0.0
PORTAL_STATIC_DIR=public

# Set this to the URL used by client devices, for example:
# CORS_ORIGIN=http://192.168.1.50:4000
CORS_ORIGIN=http://HOST-IP:4000

# Business Central — use hostname if DNS resolves, otherwise use the BC server IP.
# UAT example (hostname):
BC_ODATA_BASE_URL=http://erp-app-uat:2448/BC240/ODataV4/Company('HIJRA%20BANK')/
BC_SOAP_CODEUNIT_URL=http://erp-app-uat:2447/BC240/WS/HIJRA%20BANK/Codeunit/CuStaffPortal
BC_SOAP_PAGE_BASE_URL=http://erp-app-uat:2447/BC240/ODataV4/Company('HIJRA%20BANK')/
# UAT example (IP — use when erp-app-uat does not resolve on the host):
# BC_ODATA_BASE_URL=http://192.168.224.37:2448/BC240/ODataV4/Company('HIJRA%20BANK')/
# BC_SOAP_CODEUNIT_URL=http://192.168.224.37:2447/BC240/WS/HIJRA%20BANK/Codeunit/CuStaffPortal
# BC_SOAP_PAGE_BASE_URL=http://192.168.224.37:2447/BC240/ODataV4/Company('HIJRA%20BANK')/
BC_SOAP_NAMESPACE=urn:microsoft-dynamics-schemas/codeunit/CuStaffPortal

BC_AUTH_MODE=ntlm
BC_DOMAIN=
BC_NAV_USER=
BC_NAV_PASSWORD=

SESSION_SECRET=REPLACE-WITH-A-LONG-RANDOM-SECRET
JWT_SECRET=REPLACE-WITH-A-DIFFERENT-RANDOM-SECRET-AT-LEAST-32-CHARACTERS
JWT_TTL_SECONDS=28800

LOG_API_REQUESTS=true
LOG_BC_REQUESTS=true
BC_LOG_FILE=bc-integration.log

SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_SECURE=false
HOD_OVERRIDE_EMPNOS=
CEO_OVERRIDE_EMPNOS=
