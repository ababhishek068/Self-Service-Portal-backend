{
  "name": "self-service-portal-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Authentication & API backend for the Technology Associates EA Limited Self-Service Portal",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "seed": "tsx src/scripts/seed.ts",
    "db:migrate": "npm --prefix ../db run migrate",
    "db:deploy": "npm --prefix ../db run migrate:deploy",
    "db:seed": "npm --prefix ../db run seed",
    "db:studio": "npm --prefix ../db run studio"
  },
  "dependencies": {
    "@ssp/db": "file:../db",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
