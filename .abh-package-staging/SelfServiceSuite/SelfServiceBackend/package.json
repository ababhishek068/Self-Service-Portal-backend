{
  "name": "self-service-erp-backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc",
    "build:portal": "npm --prefix ../SelfServicePortal/self-service-portal run build:onprem && node scripts/copy-portal.mjs",
    "build:all": "npm run build && npm run build:portal",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node --test dist/approvalTableIds.test.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/node": "^25.0.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
