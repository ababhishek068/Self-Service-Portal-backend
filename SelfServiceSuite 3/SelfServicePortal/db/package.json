{
  "name": "@ssp/db",
  "version": "1.0.0",
  "private": true,
  "description": "Database layer (MySQL + Prisma) for the Self-Service Portal backend",
  "type": "module",
  "main": "./src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.js"
    }
  },
  "scripts": {
    "generate": "prisma generate",
    "migrate": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "studio": "prisma studio",
    "seed": "node prisma/seed.js",
    "reset:leave": "node scripts/resetLeave.js",
    "create-user": "node scripts/createUser.js",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "bcryptjs": "^2.4.3",
    "prisma": "^6.1.0"
  }
}
