# =============================================================================
# Database connection for the Self-Service Portal (MySQL / MariaDB)
# Copy to ".env" and adjust. Prisma reads DATABASE_URL from this file.
# =============================================================================

# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# Example for a local MySQL with user "ssp" and database "ssp_portal":
DATABASE_URL="mysql://ssp:ssp_password@localhost:3306/ssp_portal"

# Cloud MySQL/TiDB providers usually give you the full URL. If SSL is required,
# keep the provider's query parameters, for example:
# DATABASE_URL="mysql://USER:PASSWORD@HOST:4000/ssp_portal?sslaccept=strict"

# bcrypt cost factor used by the seed script (optional).
BCRYPT_ROUNDS=10
