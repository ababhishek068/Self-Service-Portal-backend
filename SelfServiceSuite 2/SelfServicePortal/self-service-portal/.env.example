# =============================================================================
# Technology Associates EA Limited — Self-Service Portal — Environment configuration
# Copy to .env and adjust per environment.
# =============================================================================

# -----------------------------------------------------------------------------
# Portal backend (REQUIRED) — Node JWT + portal API
# -----------------------------------------------------------------------------
# All portal data (requests, approvals, leave, payroll, etc.) comes from this
# URL. There is no mock or hardcoded fallback.
#
# Local development — pick the backend for each sign-in mode:
#
# Application User (portal MySQL accounts):
# VITE_AUTH_API_URL=http://localhost:4001
#
# BC365 User (Self Service ERP backend → Business Central):
VITE_BC_API_URL=http://localhost:4000
#
# If you only run the BC backend, you can set both to the same URL:
VITE_AUTH_API_URL=http://localhost:4000
#
# Portable on-prem build using the current browser hostname:
# VITE_AUTH_API_URL=
# VITE_AUTH_API_PORT=4001
# VITE_BC_API_URL=
# VITE_BC_API_PORT=4000
#
# Production (Vercel): set to your deployed server URL, e.g.:
# VITE_AUTH_API_URL=https://your-server.vercel.app

# -----------------------------------------------------------------------------
# Application metadata
# -----------------------------------------------------------------------------
VITE_APP_NAME=Self Service Portal

# -----------------------------------------------------------------------------
# Legacy: Laravel ESS — not used when VITE_AUTH_API_URL is set
# -----------------------------------------------------------------------------
# VITE_ESS_API_URL=http://192.168.224.37:81

# -----------------------------------------------------------------------------
# Legacy: direct Business Central OData (ERP connector screen only)
# -----------------------------------------------------------------------------
# VITE_ERP_BASE_URL=
# VITE_TOKEN_URL=
# VITE_CLIENT_ID=
# VITE_CLIENT_SECRET=
# VITE_ERP_COMPANY_ID=
