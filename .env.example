PORT=4000
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5173
PORTAL_STATIC_DIR=public

# Same Business Central endpoints used by /Users/abhishekbehera/ess/config/app.php
BC_ODATA_BASE_URL=http://erp-app-uat:2448/BC240/ODataV4/Company('HIJRA%20BANK')/
BC_SOAP_CODEUNIT_URL=http://erp-app-uat:2447/BC240/WS/HIJRA%20BANK/Codeunit/CuStaffPortal
BC_SOAP_PAGE_BASE_URL=http://erp-app-uat:2447/BC240/ODataV4/Company('HIJRA%20BANK')/
BC_SOAP_NAMESPACE=urn:microsoft-dynamics-schemas/codeunit/CuStaffPortal

# ESS uses NTLM-style auth for OData. Use placeholders here and real values in .env.
BC_AUTH_MODE=ntlm
BC_DOMAIN=
BC_NAV_USER=
BC_NAV_PASSWORD=

# -----------------------------------------------------------------------------
# Session / auth (used by /api/login, /api/me, /api/staff/*)
# -----------------------------------------------------------------------------
# Long random string. Required in production; a dev fallback is used otherwise.
SESSION_SECRET=change-me-in-production
# Used by the React app's Authorization: Bearer flow.
JWT_SECRET=change-me-to-a-different-random-string-at-least-32-characters
JWT_TTL_SECONDS=28800
# Correlated React -> Node -> Business Central request evidence.
LOG_API_REQUESTS=true
LOG_BC_REQUESTS=true
BC_LOG_FILE=bc-integration.log
# 'lax' for same-site / Vite proxy setups; 'none' for cross-origin (needs HTTPS).
SESSION_COOKIE_SAMESITE=lax
# 'true' when the API is served over HTTPS (required when SAMESITE=none).
SESSION_COOKIE_SECURE=false
# Optional hard override for HOD/CEO during demos (comma-separated employee Nos).
# UAT: set true to match legacy ESS (HOD menu visible for all staff).
HOD_GRANT_ALL_AUTHENTICATED=false
HOD_OVERRIDE_EMPNOS=
CEO_OVERRIDE_EMPNOS=
