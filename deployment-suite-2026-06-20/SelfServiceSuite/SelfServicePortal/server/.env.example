# =============================================================================
# Technology Associates EA Limited — Self-Service Portal — Backend configuration
# Copy to ".env" and adjust. NEVER commit the real .env.
# =============================================================================

NODE_ENV=development
# Use 4001 when SelfServiceBackend (BC365) runs on 4000
PORT=4001
HOST=0.0.0.0

# Which login strategy is active:
#   local = our own user table (works now)
#   bc    = Business Central (not implemented yet)
AUTH_PROVIDER=local

# Secret used to sign JWTs. MUST be a long random string in production.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=dev-only-insecure-secret-change-me
JWT_EXPIRES_IN=8h

# Which user store backs login:
#   db   = MySQL via Prisma (../db)  — requires DATABASE_URL below
#   json = local JSON file (no database needed)
# Use "db" for the current frontend/backend integration.
USER_STORE=db

# MySQL connection (used when USER_STORE=db). Must match db/.env.
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://ssp:ssp_password@localhost:3306/ssp_portal"
# Cloud MySQL/TiDB usually provides this full URL from its dashboard. If SSL is
# required, include the provider's query params, for example:
# DATABASE_URL="mysql://USER:PASSWORD@HOST:4000/ssp_portal?sslaccept=strict"

# Where the JSON user store lives (used when USER_STORE=json).
USER_STORE_PATH=./data/users.json
BCRYPT_ROUNDS=10

# Comma-separated list of frontend origins allowed to call this API.
CORS_ORIGINS=http://localhost:4000,http://localhost:5173,http://localhost:4173

# -----------------------------------------------------------------------------
# Business Central (only needed when AUTH_PROVIDER=bc — way #1, later)
# -----------------------------------------------------------------------------
BC_BASE_URL=
BC_COMPANY_ID=
BC_USERNAME=
BC_PASSWORD=
